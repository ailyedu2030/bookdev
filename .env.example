# =============================================================================
# AI多Agent教材编写系统 - 生产环境变量模板
# =============================================================================
# 使用方法: cp .env.example .env 并填入实际值
# 生产环境务必修改所有 "your_*" 和 "change_me_*" 占位符
# =============================================================================

# ---- 运行环境 ----
ENVIRONMENT=production
APP_NAME=textbook-writing-system
APP_VERSION=1.0.0
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# ---- MiniMax API (必填) ----
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_API_BASE=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_TIMEOUT=120

# ---- PostgreSQL ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=textbook
POSTGRES_USER=textbook_user
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_MIN_CONNECTIONS=5
POSTGRES_MAX_CONNECTIONS=25

# ---- Temporal Server ----
TEMPORAL_HOST=temporal
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=textbook-system
TEMPORAL_TASK_QUEUE=textbook-writing
TEMPORAL_MAX_RETRIES=3
TEMPORAL_RETRY_INITIAL_SECONDS=1
TEMPORAL_RETRY_MAX_SECONDS=60

# ---- Kafka ----
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CLIENT_ID=textbook-system
KAFKA_GROUP_ID=textbook-consumer
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_ENABLE_AUTO_COMMIT=true

# ---- Redis (缓存/状态) ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TIMEOUT=5

# ---- API Server ----
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_TIMEOUT=120
CORS_ORIGINS=https://textbook.example.com,https://admin.example.com

# ---- Nginx / TLS ----
NGINX_HOST=textbook.example.com
NGINX_PORT=80
NGINX_SSL_PORT=443
SSL_CERT_PATH=/etc/nginx/certs/fullchain.pem
SSL_KEY_PATH=/etc/nginx/certs/privkey.pem

# ---- Prometheus / Monitoring ----
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password
ENABLE_METRICS=true

# ---- Security ----
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
CONTENT_SECURITY_ENABLED=true
AUDIT_LOG_ENABLED=true

# ---- 素材安全 ----
MATERIAL_SCAN_ENABLED=true
MATERIAL_MAX_SIZE_MB=50
MATERIAL_ALLOWED_TYPES=application/pdf,image/png,image/jpeg,text/plain,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# ---- LLM 成本控制 ----
LLM_COST_DAILY_BUDGET_USD=100
LLM_COST_PER_1K_TOKENS=0.005
LLM_MAX_TOKENS_PER_REQUEST=8192

# ---- 备份 ----
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/backups
